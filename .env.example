DATABASE_URL="postgresql://salon:salon@localhost:5432/salon_pos?schema=public"
LOCAL_API_PORT=4000

# Clover payment terminal. Use mock for local development, rest-cloud for Clover Cloud REST Pay Display,
# rest-local for a local/mock REST Pay Display device, or ws-lan for Secure Network Pay Display over LAN.
CLOVER_TRANSPORT=mock

# Required when CLOVER_TRANSPORT=rest-cloud. Tokens/secrets stay local and must not be committed.
CLOVER_CLOUD_BASE_URL=
CLOVER_MERCHANT_ID=
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_ACCESS_TOKEN=
CLOVER_DEVICE_ID=
CLOVER_POS_ID=
CLOVER_REMOTE_APP_ID=
CLOVER_PAYMENT_TIMEOUT_MS=120000
