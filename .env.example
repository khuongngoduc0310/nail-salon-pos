DATABASE_URL="postgresql://salon:salon@localhost:5432/salon_pos?schema=public"
LOCAL_API_PORT=4000

# Clover payment terminal. Use mock for local development, ws-cloud for Clover Remote Pay Cloud,
# rest-cloud for Clover Cloud REST Pay Display, rest-local for a local/mock REST Pay Display device,
# or ws-lan for Secure Network Pay Display over LAN.
CLOVER_TRANSPORT=ws-cloud

# Required when CLOVER_TRANSPORT=rest-cloud. Tokens stay local and must not be committed.
# Production US Cloud REST Pay Display commonly uses https://api.clover.com/connect.
CLOVER_CLOUD_BASE_URL=https://api.clover.com/connect
CLOVER_ACCESS_TOKEN=
CLOVER_DEVICE_ID=C035UT24950367
CLOVER_POS_ID=owner-pos
# Optional context/diagnostics for configured merchant/app.
CLOVER_MERCHANT_ID=HDSPNPKW4VXZ1
CLOVER_APP_ID=P6N5P0HHFG3RE
CLOVER_REMOTE_APP_ID=RQ07XH5Z3EX44.BT1G67W0JJFVC

# Required when CLOVER_TRANSPORT=ws-cloud.
CLOVER_CLOUD_SERVER=https://api.clover.com
CLOVER_FRIENDLY_ID=TL Nails And Spa 625
CLOVER_PAYMENT_TIMEOUT_MS=120000
