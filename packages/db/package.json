{
  "name": "@nail/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "prisma:generate": "node scripts/with-root-env.mjs prisma generate",
    "prisma:migrate": "node scripts/with-root-env.mjs prisma generate && node scripts/with-root-env.mjs prisma migrate deploy",
    "prisma:migrate:dev": "node scripts/with-root-env.mjs prisma migrate dev",
    "prisma:seed": "node scripts/with-root-env.mjs prisma db seed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
