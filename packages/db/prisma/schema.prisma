generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  worker
  customer

  @@map("user_role")
}

enum WorkerStatus {
  available
  in_service
  on_break
  off_today
  appointment_only

  @@map("worker_status")
}

enum CheckinStatus {
  waiting
  assigned
  in_service
  ready_for_checkout
  paid
  cancelled
  no_show

  @@map("checkin_status")
}

enum AppointmentStatus {
  scheduled
  confirmed
  checked_in
  in_service
  completed
  cancelled
  no_show

  @@map("appointment_status")
}

enum TurnStatus {
  assigned
  in_service
  completed
  skipped
  cancelled

  @@map("turn_status")
}

enum TurnType {
  walk_in
  appointment
  requested_worker
  manual

  @@map("turn_type")
}

enum SaleStatus {
  draft
  open
  partially_paid
  paid
  refunded
  voided

  @@map("sale_status")
}

enum SaleItemStatus {
  active
  refunded
  voided

  @@map("sale_item_status")
}

enum PaymentMethod {
  cash
  card
  gift_card
  other

  @@map("payment_method")
}

enum PaymentStatus {
  pending
  approved
  declined
  cancelled
  failed
  refunded

  @@map("payment_status")
}

enum DiscountType {
  amount
  percent

  @@map("discount_type")
}

enum GiftCardStatus {
  active
  disabled
  expired

  @@map("gift_card_status")
}

enum GiftCardTxType {
  issue
  redeem
  refund
  adjustment

  @@map("gift_card_tx_type")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  phone        String?
  email        String?  @unique
  role         UserRole
  passwordHash String?  @map("password_hash")
  pinHash      String?  @map("pin_hash")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz

  worker       Worker?
  auditLogs    AuditLog[]

  @@map("users")
}

model Worker {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @unique @map("user_id") @db.Uuid
  displayName    String       @map("display_name")
  commissionRate Decimal      @map("commission_rate") @db.Decimal(5, 4)
  currentStatus  WorkerStatus @default(available) @map("current_status")
  active         Boolean      @default(true)
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz

  user           User         @relation(fields: [userId], references: [id])
  appointments   Appointment[]
  checkins       Checkin[]    @relation("RequestedWorker")
  turns          Turn[]       @relation("TurnWorker")
  suggestedTurns Turn[]       @relation("SuggestedWorker")
  saleItems      SaleItem[]

  @@map("workers")
}

model Customer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  appointments Appointment[]
  checkins     Checkin[]
  turns        Turn[]
  sales        Sale[]

  @@map("customers")
}

model ServiceCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  services Service[]

  @@map("service_categories")
}

model Service {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  name            String
  description     String?
  priceCents      Int      @map("price_cents")
  durationMinutes Int      @default(30) @map("duration_minutes")
  active          Boolean  @default(true)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz

  category            ServiceCategory     @relation(fields: [categoryId], references: [id])
  appointmentServices AppointmentService[]
  saleItems           SaleItem[]

  @@map("services")
}

model Appointment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId      String?           @map("customer_id") @db.Uuid
  workerId        String?           @map("worker_id") @db.Uuid
  startTime       DateTime          @map("start_time") @db.Timestamptz
  endTime         DateTime          @map("end_time") @db.Timestamptz
  status          AppointmentStatus @default(scheduled)
  notes           String?
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @default(now()) @map("updated_at") @db.Timestamptz

  customer Customer? @relation(fields: [customerId], references: [id])
  worker   Worker?   @relation(fields: [workerId], references: [id])
  services AppointmentService[]
  checkins Checkin[]
  turns    Turn[]
  sales    Sale[]

  @@index([workerId, startTime, endTime])
  @@map("appointments")
}

model AppointmentService {
  id                    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId         String @map("appointment_id") @db.Uuid
  serviceId             String @map("service_id") @db.Uuid
  priceCentsAtBooking   Int    @map("price_cents_at_booking")
  durationMinutes       Int    @default(30) @map("duration_minutes")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@map("appointment_services")
}

model Checkin {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId        String?       @map("customer_id") @db.Uuid
  appointmentId     String?       @map("appointment_id") @db.Uuid
  status            CheckinStatus @default(waiting)
  requestedWorkerId String?       @map("requested_worker_id") @db.Uuid
  notes             String?
  checkedInAt       DateTime      @default(now()) @map("checked_in_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  customer        Customer?    @relation(fields: [customerId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  requestedWorker Worker?      @relation("RequestedWorker", fields: [requestedWorkerId], references: [id])
  turns           Turn[]
  sales           Sale[]

  @@index([status, checkedInAt])
  @@map("checkins")
}

model Turn {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workerId            String     @map("worker_id") @db.Uuid
  customerId          String?    @map("customer_id") @db.Uuid
  checkinId           String?    @map("checkin_id") @db.Uuid
  appointmentId       String?    @map("appointment_id") @db.Uuid
  saleId              String?    @map("sale_id") @db.Uuid
  turnType            TurnType   @default(manual) @map("turn_type")
  status              TurnStatus @default(assigned)
  assignedByUserId    String?    @map("assigned_by_user_id") @db.Uuid
  suggestedWorkerId   String?    @map("suggested_worker_id") @db.Uuid
  ownerOverrideReason String?    @map("owner_override_reason")
  startedAt           DateTime?  @map("started_at") @db.Timestamptz
  endedAt             DateTime?  @map("ended_at") @db.Timestamptz
  completedAt         DateTime?  @map("completed_at") @db.Timestamptz
  skippedAt           DateTime?  @map("skipped_at") @db.Timestamptz
  skippedReason       String?    @map("skipped_reason")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime   @default(now()) @map("updated_at") @db.Timestamptz

  worker          Worker       @relation("TurnWorker", fields: [workerId], references: [id])
  customer        Customer?    @relation(fields: [customerId], references: [id])
  checkin         Checkin?     @relation(fields: [checkinId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  sale            Sale?        @relation(fields: [saleId], references: [id])
  suggestedWorker Worker?      @relation("SuggestedWorker", fields: [suggestedWorkerId], references: [id])

  @@index([workerId, status])
  @@index([startedAt])
  @@map("turns")
}

model Sale {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId         String?    @map("customer_id") @db.Uuid
  appointmentId      String?    @map("appointment_id") @db.Uuid
  checkinId          String?    @map("checkin_id") @db.Uuid
  receiptNumber      String?    @unique @map("receipt_number")
  status             SaleStatus @default(draft)
  subtotalCents      Int        @default(0) @map("subtotal_cents")
  discountTotalCents Int        @default(0) @map("discount_total_cents")
  taxTotalCents      Int        @default(0) @map("tax_total_cents")
  tipTotalCents      Int        @default(0) @map("tip_total_cents")
  totalCents         Int        @default(0) @map("total_cents")
  amountPaidCents    Int        @default(0) @map("amount_paid_cents")
  createdByUserId    String?    @map("created_by_user_id") @db.Uuid
  completedAt        DateTime?  @map("completed_at") @db.Timestamptz
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @default(now()) @map("updated_at") @db.Timestamptz

  customer    Customer?    @relation(fields: [customerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  checkin     Checkin?     @relation(fields: [checkinId], references: [id])
  turns       Turn[]
  items       SaleItem[]
  payments    Payment[]
  refunds     Refund[]
  discounts   Discount[]
  receipts    Receipt[]

  @@index([completedAt])
  @@map("sales")
}

model SaleItem {
  id                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId                 String         @map("sale_id") @db.Uuid
  serviceId              String?        @map("service_id") @db.Uuid
  workerId               String         @map("worker_id") @db.Uuid
  serviceNameSnapshot    String         @map("service_name_snapshot")
  categoryNameSnapshot   String?        @map("category_name_snapshot")
  priceCents             Int            @map("price_cents")
  discountCents          Int            @default(0) @map("discount_cents")
  finalServiceCents      Int            @map("final_service_cents")
  commissionRateSnapshot Decimal        @map("commission_rate_snapshot") @db.Decimal(5, 4)
  workerCommissionCents  Int            @default(0) @map("worker_commission_cents")
  tipCents               Int            @default(0) @map("tip_cents")
  workerTotalCents       Int            @default(0) @map("worker_total_cents")
  businessCents          Int            @default(0) @map("business_cents")
  status                 SaleItemStatus @default(active)
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz

  sale      Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  service   Service?   @relation(fields: [serviceId], references: [id])
  worker    Worker     @relation(fields: [workerId], references: [id])
  discounts Discount[]

  @@index([workerId])
  @@map("sale_items")
}

model Payment {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId               String        @map("sale_id") @db.Uuid
  method               PaymentMethod
  provider             String?
  providerPaymentId    String?       @map("provider_payment_id")
  providerOrderId      String?       @map("provider_order_id")
  idempotencyKey       String?       @unique @map("idempotency_key")
  amountCents          Int           @map("amount_cents")
  tipCents             Int           @default(0) @map("tip_cents")
  status               PaymentStatus @default(pending)
  cardBrand            String?       @map("card_brand")
  cardLast4            String?       @map("card_last4")
  authCode             String?       @map("auth_code")
  rawProviderReference Json?         @map("raw_provider_reference") @db.JsonB
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([saleId])
  @@map("payments")
}

model Refund {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId            String   @map("sale_id") @db.Uuid
  paymentId         String?  @map("payment_id") @db.Uuid
  amountCents       Int      @map("amount_cents")
  reason            String?
  approvedByUserId  String?  @map("approved_by_user_id") @db.Uuid
  providerRefundId  String?  @map("provider_refund_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  sale    Sale     @relation(fields: [saleId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("refunds")
}

model Discount {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId           String       @map("sale_id") @db.Uuid
  saleItemId       String?      @map("sale_item_id") @db.Uuid
  type             DiscountType
  amountCents      Int?         @map("amount_cents")
  percent          Decimal?     @db.Decimal(5, 4)
  reason           String?
  approvedByUserId String?      @map("approved_by_user_id") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz

  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleItem SaleItem? @relation(fields: [saleItemId], references: [id], onDelete: Cascade)

  @@map("discounts")
}

model GiftCard {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codeHash     String         @unique @map("code_hash")
  balanceCents Int            @default(0) @map("balance_cents")
  status       GiftCardStatus @default(active)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @default(now()) @map("updated_at") @db.Timestamptz

  transactions GiftCardTransaction[]

  @@map("gift_cards")
}

model GiftCardTransaction {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  giftCardId      String         @map("gift_card_id") @db.Uuid
  saleId          String?        @map("sale_id") @db.Uuid
  amountCents     Int            @map("amount_cents")
  transactionType GiftCardTxType @map("transaction_type")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  giftCard GiftCard @relation(fields: [giftCardId], references: [id])

  @@map("gift_card_transactions")
}

model Receipt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId          String   @map("sale_id") @db.Uuid
  printStatus     String   @default("not_printed") @map("print_status")
  smsStatus       String   @default("not_sent") @map("sms_status")
  emailStatus     String   @default("not_sent") @map("email_status")
  receiptDataJson Json     @map("receipt_data_json") @db.JsonB
  printedAt       DateTime? @map("printed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("receipts")
}

model SyncEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  operation  String
  payload    Json     @db.JsonB
  status     String   @default("pending")
  attempts   Int      @default(0)
  lastError  String?  @map("last_error")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("sync_events")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  metadataJson Json?    @map("metadata_json") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
